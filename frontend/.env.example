# ============================================================
# ARIA Frontend — Environment Variables
# Copy to .env.local for local development.
# In production (Vercel), set these in the project's
# Environment Variables settings.
# ============================================================

# Agent backend URL.
# Local:      http://localhost:8000
# Production: https://aria-agent-<hash>-<region>.a.run.app
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# Optional: override the MCP server URL surfaced to the user
# (About page, footer). Leave blank to hide.
NEXT_PUBLIC_MCP_SERVER_URL=

# Optional: Prompt Opinion marketplace listing URL. Shown on
# the About page as "Available on Prompt Opinion".
NEXT_PUBLIC_PROMPT_OPINION_URL=