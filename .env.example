# ============================================================
# ARIA MCP Server — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

MCP_SERVER_PORT=8080
RUST_LOG=info

# ---- LLM Configuration -------------------------------------
# ARIA supports two auth modes for Gemini. Pick one via LLM_MODE.
#
#   vertex_ai  → production mode (GCP IAM, service account)
#   ai_studio  → hackathon/demo mode (API key from Google AI Studio)
#
# The Prompt Opinion platform currently accepts an AI Studio API key
# during registration, so for that demo flow set LLM_MODE=ai_studio.
# Otherwise keep vertex_ai for production with IAM access control.
LLM_MODE=vertex_ai

# ---- Mode 1: Vertex AI (production, default) ---------------
# Auth via GCP service account (set GOOGLE_APPLICATION_CREDENTIALS
# to the JSON key path, or use Workload Identity on Cloud Run).
# Required role: roles/aiplatform.user
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=asia-southeast2

# ---- Mode 2: Google AI Studio (hackathon/demo) -------------
# Get your API key at https://aistudio.google.com/app/apikey
# Leave blank when LLM_MODE=vertex_ai.
GOOGLE_AI_STUDIO_API_KEY=

# ---- Shared: Gemini model ----------------------------------
GEMINI_MODEL=gemini-2.5-pro

# ---- FHIR Integration (SHARP Extension Specs) --------------
# Public HAPI FHIR sandbox for the hackathon demo. In production,
# replace with the partner EHR's FHIR endpoint. No key required
# for the sandbox; production endpoints use SMART-on-FHIR tokens
# propagated by Prompt Opinion via the SHARP Extension Specs.
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_AUTH_MODE=none
# When running behind Prompt Opinion, SHARP headers carry the
# patient context and bearer token. These variables are the
# fallback used for local testing only.
FHIR_DEFAULT_PATIENT_ID=

# ---- External Pharmacology APIs ----------------------------
# OpenFDA (key required): https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=your-openfda-api-key
# RxNorm  (no key): https://rxnav.nlm.nih.gov/RxNormAPIs.html
# PubMed  (no key): https://www.ncbi.nlm.nih.gov/home/develop/api/
# DrugBank Open (no key): https://go.drugbank.com/releases/latest#open-data