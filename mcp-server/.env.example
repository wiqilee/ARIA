# ============================================================
# ARIA MCP Server — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

MCP_SERVER_PORT=8080
RUST_LOG=info

# ---- LLM: Gemini 2.5 Pro via Vertex AI --------------------
# No API key needed.
# Access is controlled by GCP service account IAM roles.
# Required role: roles/aiplatform.user
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEXAI_LOCATION=asia-southeast2
GEMINI_MODEL=gemini-2.5-pro

# ---- External APIs -----------------------------------------
# OpenFDA (key required): https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=your-openfda-api-key
# RxNorm  (no key): https://rxnav.nlm.nih.gov/RxNormAPIs.html
# PubMed  (no key): https://www.ncbi.nlm.nih.gov/home/develop/api/
# DrugBank Open (no key): https://go.drugbank.com/releases/latest#open-data